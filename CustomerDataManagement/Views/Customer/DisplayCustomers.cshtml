@model IEnumerable<Customer>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"></script>

<div class="container mt-2">

    <h2 class="text-center mb-2" style="background-color:darkblue;color:deepskyblue;border:7px">Customer Management</h2>

    <!-- ADD BUTTON -->
    <div class="mb-2 text-end">
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addModal">
            Add Customer
        </button>
    </div>

    <table class="table table-striped table-hover shadow">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Balance</th>
                <th>City</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var customer in Model)
            {
                <tr>
                    <td>@customer.Custid</td>
                    <td>@customer.Name</td>
                    <td>@customer.Balance</td>
                    <td>@customer.City</td>
                    <td>@customer.Status</td>

                    <td>
                        
                        <button class="btn btn-info btn-sm detailsBtn"
                                data-id="@customer.Custid"
                                data-name="@customer.Name"
                                data-city="@customer.City"
                                data-balance="@customer.Balance"
                                data-status="@customer.Status">
                            Details
                        </button>
                        <button class="btn btn-primary btn-sm editBtn"
                                data-id="@customer.Custid"
                                data-name="@customer.Name"
                                data-city="@customer.City"
                                data-balance="@customer.Balance"
                                data-status="@customer.Status">
                            Edit
                        </button>


                        <a asp-action="DeleteCustomer" asp-route-Custid="@customer.Custid"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Are you sure?')">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>
<div class="modal fade" id="customerModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">

            <div class="modal-header">
                <h5 class="modal-title">Edit Customer</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form asp-action="UpdateCustomer" method="post">

                    <input type="hidden" id="Custid" name="Custid" />

                    <div class="mb-3">
                        <input type="text" id="Name" name="Name" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <input type="text" id="City" name="City" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <input type="text" id="Balance" name="Balance" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <input type="text" id="Status" name="Status" class="form-control" />
                    </div>

                    <button class="btn btn-success w-100">Update</button>
                </form>
            </div>

        </div>
    </div>
</div>


<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">

            <div class="modal-header">
                <h5 class="modal-title">Add Customer</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form asp-action="AddCustomer" method="post">
                    <div class="mb-3">
                        <input name="Custid" class="form-control" placeholder="Customer Id" />
                    </div>
                    <div class="mb-3">
                        <input name="Name" class="form-control" placeholder="Name" />
                    </div>

                    <div class="mb-3">
                        <input name="City" class="form-control" placeholder="City" />
                    </div>

                    <div class="mb-3">
                        <input name="Balance" class="form-control" placeholder="Balance" />
                    </div>

                    <div class="mb-3">
                        <input name="Status" class="form-control" placeholder="Status" />
                    </div>

                    <button class="btn btn-success w-100">Save</button>

                </form>
            </div>

        </div>
    </div>
</div>



<div class="modal fade" id="detailsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">

            <div class="modal-header">
                <h5 class="modal-title">Customer Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="text" id="d_Custid" class="form-control mb-2" readonly />
                <input type="text" id="d_Name" class="form-control mb-2" readonly />
                <input type="text" id="d_City" class="form-control mb-2" readonly />
                <input type="text" id="d_Balance" class="form-control mb-2" readonly />
                <input type="text" id="d_Status" class="form-control mb-2" readonly />
            </div>

        </div>
    </div>
</div>


<script>
    
    document.querySelectorAll(".editBtn").forEach(btn => {
    btn.addEventListener("click", function () {
    Custid.value = this.dataset.id;
    Name.value = this.dataset.name;
    City.value = this.dataset.city;
    Balance.value = this.dataset.balance;
    Status.value = this.dataset.status;

    new bootstrap.Modal(customerModal).show();
    });
    });

 
    document.querySelectorAll(".detailsBtn").forEach(btn => {
    btn.addEventListener("click", function () {
    d_Custid.value = this.dataset.id;
    d_Name.value = this.dataset.name;
    d_City.value = this.dataset.city;
    d_Balance.value = this.dataset.balance;
    d_Status.value = this.dataset.status;

    new bootstrap.Modal(detailsModal).show();
    });
    });

    window.onload = function () {
    var open = '@TempData["OpenModal"]';
    if (open === "Add") {
    new bootstrap.Modal(document.getElementById('addModal')).show();
    }
    };
</script>